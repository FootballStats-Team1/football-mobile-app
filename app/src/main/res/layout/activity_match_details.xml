<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/palette_blue_6"
    tools:context=".MatchDetailsActivity">

    <LinearLayout
        android:id="@+id/matchHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="32dp"
        android:paddingBottom="32dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:id="@+id/imgHomeLogo"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:contentDescription="@string/teamStats" />

            <TextView
                android:id="@+id/tvHomeTeam"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center"
                tools:text="ΑΕΚ" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <TextView
                android:id="@+id/tvScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="32sp"
                android:textStyle="bold"
                tools:text="1 - 1" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/white"
                android:textSize="13sp"
                tools:text="Τελικό" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:id="@+id/imgAwayLogo"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:contentDescription="@string/teamStats" />

            <TextView
                android:id="@+id/tvAwayTeam"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center"
                tools:text="Παναθηναϊκός" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/linearLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:layout_constraintTop_toBottomOf="@id/matchHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/teamStatsBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:backgroundTint="@color/palette_blue_2"
            android:text="@string/teamStats"
            android:textStyle="bold" />

        <Button
            android:id="@+id/personalStatsBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:backgroundTint="@color/palette_blue_2"
            android:text="@string/personalStats"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/teamSelectorLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone"
        android:layout_marginTop="12dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:layout_constraintTop_toBottomOf="@id/linearLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnHomeTeam"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:backgroundTint="@color/palette_blue_3"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:padding="10dp"
            android:scaleType="fitCenter"
            android:contentDescription="@string/teamStats" />

        <ImageButton
            android:id="@+id/btnAwayTeam"
            android:layout_width="0dp"
            android:backgroundTint="@color/palette_blue_3"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:contentDescription="@string/teamStats" />
    </LinearLayout>

    <ScrollView
        android:id="@+id/statsScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:layout_marginTop="12dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:layout_constraintTop_toBottomOf="@id/linearLayout"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/statsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <LinearLayout style="@style/StatRow">
                <TextView
                    android:id="@+id/tvHomePossession"
                    style="@style/StatValue"
                    tools:text="55%" />

                <TextView
                    style="@style/StatLabel"
                    android:text="@string/stat_possession" />

                <TextView
                    android:id="@+id/tvAwayPossession"
                    style="@style/StatValue"
                    tools:text="45%" />
            </LinearLayout>

            <LinearLayout style="@style/StatRow">
                <TextView
                    android:id="@+id/tvHomeShots"
                    style="@style/StatValue"
                    tools:text="12" />

                <TextView
                    style="@style/StatLabel"
                    android:text="@string/stat_shots" />

                <TextView
                    android:id="@+id/tvAwayShots"
                    style="@style/StatValue"
                    tools:text="8" />
            </LinearLayout>

            <LinearLayout style="@style/StatRow">
                <TextView
                    android:id="@+id/tvHomeShotsOn"
                    style="@style/StatValue"
                    tools:text="5" />

                <TextView
                    style="@style/StatLabel"
                    android:text="@string/stat_shots_on" />

                <TextView
                    android:id="@+id/tvAwayShotsOn"
                    style="@style/StatValue"
                    tools:text="3" />
            </LinearLayout>

            <LinearLayout style="@style/StatRow">
                <TextView
                    android:id="@+id/tvHomePasses"
                    style="@style/StatValue"
                    tools:text="420" />

                <TextView
                    style="@style/StatLabel"
                    android:text="@string/stat_passes" />

                <TextView
                    android:id="@+id/tvAwayPasses"
                    style="@style/StatValue"
                    tools:text="350" />
            </LinearLayout>

            <LinearLayout style="@style/StatRow">
                <TextView
                    android:id="@+id/tvHomePassAcc"
                    style="@style/StatValue"
                    tools:text="88%" />

                <TextView
                    style="@style/StatLabel"
                    android:text="@string/stat_pass_acc" />

                <TextView
                    android:id="@+id/tvAwayPassAcc"
                    style="@style/StatValue"
                    tools:text="82%" />
            </LinearLayout>

            <LinearLayout style="@style/StatRow">
                <TextView
                    android:id="@+id/tvHomeTackles"
                    style="@style/StatValue"
                    tools:text="18" />

                <TextView
                    style="@style/StatLabel"
                    android:text="@string/stat_tackles" />

                <TextView
                    android:id="@+id/tvAwayTackles"
                    style="@style/StatValue"
                    tools:text="22" />
            </LinearLayout>

            <LinearLayout style="@style/StatRow">
                <TextView
                    android:id="@+id/tvHomeCorners"
                    style="@style/StatValue"
                    tools:text="6" />

                <TextView
                    style="@style/StatLabel"
                    android:text="@string/stat_corners" />

                <TextView
                    android:id="@+id/tvAwayCorners"
                    style="@style/StatValue"
                    tools:text="4" />
            </LinearLayout>

            <LinearLayout style="@style/StatRow">
                <TextView
                    android:id="@+id/tvHomeFouls"
                    style="@style/StatValue"
                    tools:text="11" />

                <TextView
                    style="@style/StatLabel"
                    android:text="@string/stat_fouls" />

                <TextView
                    android:id="@+id/tvAwayFouls"
                    style="@style/StatValue"
                    tools:text="14" />
            </LinearLayout>

            <LinearLayout style="@style/StatRow">
                <TextView
                    android:id="@+id/tvHomeYellows"
                    style="@style/StatValue"
                    tools:text="2" />

                <TextView
                    style="@style/StatLabel"
                    android:text="@string/stat_yellows" />

                <TextView
                    android:id="@+id/tvAwayYellows"
                    style="@style/StatValue"
                    tools:text="1" />
            </LinearLayout>

            <LinearLayout style="@style/StatRow">
                <TextView
                    android:id="@+id/tvHomeReds"
                    style="@style/StatValue"
                    tools:text="0" />

                <TextView
                    style="@style/StatLabel"
                    android:text="@string/stat_reds" />

                <TextView
                    android:id="@+id/tvAwayReds"
                    style="@style/StatValue"
                    tools:text="0" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <ScrollView
        android:id="@+id/lineupsScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:layout_marginTop="12dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        app:layout_constraintTop_toBottomOf="@id/teamSelectorLayout"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/starting"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                android:paddingBottom="12dp" />

            <LinearLayout
                android:id="@+id/layoutSelectedStarters"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/substitutes"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:gravity="center"
                android:textStyle="bold"
                android:layout_marginTop="24dp"
                android:paddingBottom="12dp" />

            <LinearLayout
                android:id="@+id/layoutSelectedSubs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"/>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>