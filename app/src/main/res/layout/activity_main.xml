<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/palette_blue_6"
    tools:context=".MainActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="32dp">

        <Button
            android:id="@+id/Helpbtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:backgroundTint="@color/palette_blue_4"
            android:onClick="helpEnter"
            android:text="@string/Helpbtn"
            android:textColor="#FFFFFF"
            app:cornerRadius="16dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <Button
            android:id="@+id/Languagebtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:backgroundTint="@color/palette_blue_4"
            android:onClick="changeLanguage"
            android:text="@string/Languagebtn"
            android:textColor="#FFFFFF"
            app:cornerRadius="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/imgLogo"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_marginTop="64dp"
            android:src="@drawable/epo"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/Languagebtn" />

        <LinearLayout
            android:id="@+id/loginContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="64dp"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/imgLogo">

            <TextView
                android:id="@+id/SignInLbl"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="@string/SignInlbl"
                android:textColor="@color/palette_blue_1"
                android:textSize="20sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/Userbtn"
                android:layout_width="250dp"
                android:layout_height="60dp"
                android:layout_marginBottom="16dp"
                android:backgroundTint="@color/palette_blue_2"
                android:onClick="userEnter"
                android:text="@string/Userbtn"
                android:textColor="#FFFFFF"
                app:cornerRadius="16dp" />

            <Button
                android:id="@+id/StatisticAnalystbtn"
                android:layout_width="250dp"
                android:layout_height="60dp"
                android:backgroundTint="@color/palette_blue_3"
                android:onClick="analystEnter"
                android:text="@string/StatisticAnalystbtn"
                android:textColor="#FFFFFF"
                app:cornerRadius="16dp" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>